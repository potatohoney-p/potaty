# Multi-stage build for the Potaty backend. Stage 1 builds the Gradle
# `application` plugin distribution (the :backend:installDist task lays out bin/ + lib/ with a
# launcher script); stage 2 is a slim JRE that just runs it. The build context is the repo root
# so the whole multi-module Gradle project (settings.gradle.kts, gradle/, :diagram-ir, etc.) is
# available — see docker-compose.yml which sets `context: .`.

# ---- build stage ----------------------------------------------------------------------------
FROM gradle:9.6-jdk17 AS build
WORKDIR /home/gradle/project

# Copy the whole project (multi-module: backend depends on :diagram-ir and :renderer-codegen).
COPY --chown=gradle:gradle . .

# Use the checked-in wrapper so local, CI, and container builds resolve the same Gradle version.
RUN chmod +x gradlew && \
    ./gradlew :backend:installDist --no-daemon -Dorg.gradle.parallel=false

# ---- runtime stage --------------------------------------------------------------------------
FROM eclipse-temurin:17-jre-jammy AS runtime

LABEL org.opencontainers.image.title="Potaty backend" \
      org.opencontainers.image.description="Source-grounded diagram generation API" \
      org.opencontainers.image.source="https://github.com/potatohoney-p/potaty" \
      org.opencontainers.image.licenses="Apache-2.0"

# curl is used only by the container healthcheck. Keep the runtime package set minimal.
RUN apt-get update && \
    apt-get install --yes --no-install-recommends ca-certificates curl && \
    rm -rf /var/lib/apt/lists/* && \
    groupadd --system --gid 10001 potaty && \
    useradd --system --uid 10001 --gid potaty --home-dir /app --shell /usr/sbin/nologin potaty

WORKDIR /app

# The application-plugin distribution: launcher under bin/, jars under lib/.
COPY --from=build --chown=potaty:potaty /home/gradle/project/backend/build/install/backend/ /app/

# Safe standalone defaults; Compose or the deployment environment supplies persistent storage.
ENV POTATY_HOST=0.0.0.0 \
    POTATY_PORT=8080 \
    POTATY_ENV=development \
    POTATY_DB_MODE=h2 \
    POTATY_AUTH_MODE=jwt \
    POTATY_DEV_AUTH=false \
    JAVA_OPTS="-XX:MaxRAMPercentage=75.0 -Djava.io.tmpdir=/tmp"

EXPOSE 8080

# The image fails closed until JWT settings are supplied; it never seeds a repository-known token.
USER potaty:potaty

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl --fail --silent --show-error http://127.0.0.1:8080/health/ready > /dev/null || exit 1

# The launcher script generated by the application plugin (mainClass = com.potaty.backend.ApplicationKt).
ENTRYPOINT ["/app/bin/backend"]
