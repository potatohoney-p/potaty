# Docker Compose reads `.env` automatically. The JVM application does not; export these variables
# in your shell when running `:backend:run` directly.
#
# Copy this file to `.env`, generate independent random values, and never commit `.env`.
#   openssl rand -hex 32

# Runtime profile and host port for the local Compose backend.
POTATY_ENV=development
POTATY_HTTP_PORT=8090

# PostgreSQL used by the Compose stack.
POTATY_DB_NAME=potaty
POTATY_DB_USER=potaty
POTATY_DB_PASSWORD=
POTATY_DB_POOL_SIZE=10
POTATY_DB_MIGRATE=true

# Explicit local authentication and deterministic development identity. Never use dev mode on a
# public deployment. POTATY_DEV_AUTH remains a compatibility switch; POTATY_AUTH_MODE is canonical.
POTATY_AUTH_MODE=dev
POTATY_DEV_AUTH=true
POTATY_DEV_TOKEN=
POTATY_DEV_WORKSPACE_ID=00000000-0000-0000-0000-000000000001
POTATY_DEV_USER_ID=00000000-0000-0000-0000-000000000002
POTATY_DEV_PROJECT_ID=00000000-0000-0000-0000-000000000010

# JWT mode for a self-hosted identity gateway. These values are ignored in dev mode. Generate at
# least 32 random bytes for the HMAC secret; do not use the examples as production identifiers.
POTATY_JWT_ISSUER=
POTATY_JWT_AUDIENCE=
POTATY_JWT_SECRET=
POTATY_JWT_TTL_SECONDS=3600

# Browser origin allowed to call the backend.
POTATY_CORS_ORIGINS=http://localhost:8080

# Local AES/GCM envelope-key material. This is not production KMS integration.
POTATY_CREDENTIAL_KMS_KEY=
# Disabled by default. Enable only for a legally approved BYO/self-hosted Anthropic OAuth flow;
# consumer subscription tokens are not supported credentials.
POTATY_ALLOW_PROVIDER_OAUTH=false
# A non-positive cap disables enforcement. Transcription figures are configurable estimates, not a
# provider billing contract; update them when your provider/model pricing or audio mix changes.
POTATY_WORKSPACE_MONTHLY_COST_CAP_USD=50
POTATY_TRANSCRIPTION_USD_PER_MINUTE=0.006
POTATY_TRANSCRIPTION_RESERVATION_BITRATE_BPS=4000

# Optional OpenAI enrichment. Without this key, deterministic extraction still runs.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHEAP_STRUCTURED_MODEL=gpt-4o-mini
OPENAI_MID_STRUCTURED_MODEL=gpt-4o
OPENAI_HIGH_REASONING_MODEL=o1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Optional Anthropic routing for credentials managed through the backend.
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_CHEAP_STRUCTURED_MODEL=claude-3-5-haiku-latest
ANTHROPIC_MID_STRUCTURED_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_HIGH_REASONING_MODEL=claude-opus-4-latest

# Optional GitHub App integration. Public-repository URL indexing works without these values.
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WEB_BASE_URL=https://github.com
GITHUB_APP_ID=
# Inject the PEM through your shell or secret manager. Do not paste a private key into a committed file.
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# The private-repository connection flow is all-or-nothing. When APP_ID/key are set, configure
# every value below. Keep OAuth/state secrets in your secret manager, not this file.
GITHUB_APP_SLUG=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8090/api/v1/github/oauth/callback
POTATY_PUBLIC_BASE_URL=http://localhost:8090
GITHUB_CONNECT_STATE_SECRET=
GITHUB_CONNECT_STATE_TTL_SECONDS=900
GITHUB_MAX_FILE_BYTES=1000000
GITHUB_MAX_FILES_PER_INDEX=2000
